{
  "name": "iCloud隐藏邮箱助手",
  "description": "在浏览器中使用 iCloud 隐藏邮箱，支持中文界面和批量生成。",
  "manifest_version": 3,
  "background": {
    "service_worker": "background.bundle.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icon-32.png"
  },
  "options_page": "options.html",
  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "icloud_com_simulation_headers",
        "enabled": true,
        "path": "rules.json"
      }
    ]
  },
  "permissions": [
    "declarativeNetRequest",
    "storage",
    "tabs",
    "alarms",
    "contextMenus",
    "webRequest",
    "notifications"
  ],
  "host_permissions": [
    "https://*.icloud.com/*",
    "https://*.icloud.com.cn/*",
    "http://127.0.0.1:37651/*"
  ],
  "icons": {
    "16": "icon-16.png",
    "32": "icon-32.png",
    "48": "icon-48.png",
    "128": "icon-128.png"
  }
}
